# ============================================================
# Glass Library — Environment Variables
# Braddock fills these in Render's Environment tab (Part 7)
# ============================================================

# Database — from neon.tech → New Project → connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/glasslibrary?sslmode=require

# Cloudflare R2 — from dash.cloudflare.com → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=glass-library

# Google Gemini — from aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=

# App
PORT=3000
NODE_ENV=production

# Optional: disable AI classification/summarization (e.g. local dev w/o key)
# When false (or GEMINI_API_KEY is empty), upload falls back to regex-only.
ENABLE_AI=true

# Optional: max upload size in MB (default 50)
MAX_UPLOAD_MB=50

# Optional: signed URL expiry in seconds (default 300 = 5 min)
SIGNED_URL_EXPIRES=300